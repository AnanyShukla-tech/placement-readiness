{
  "name": "final-project",
  "version": "1.0.0",
  "description": "This project runs locally and uses JSON/CSV files as the data source. It includes:",
  "main": "main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "electron:start": "electron .",
    "dev": "concurrently \"npm run start --prefix frontend\" \"wait-on http://localhost:3000 && electron .\"",
    "build:frontend": "npm run build --prefix frontend",
    "build:win": "npm run build:frontend && electron-builder --win"
  },
  "build": {
    "appId": "com.placifyai.app",
    "productName": "Placify AI",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "files": [
      "main.js",
      "preload.js",
      "frontend/build/**/*"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/07Jatin/Collage-placement-readiness-and-gap-analysis-testing-1-.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/07Jatin/Collage-placement-readiness-and-gap-analysis-testing-1-/issues"
  },
  "homepage": "https://github.com/07Jatin/Collage-placement-readiness-and-gap-analysis-testing-1-#readme",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1",
    "wait-on": "^9.0.5"
  }
}
